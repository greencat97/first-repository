<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Global Economic Pulse — Live 3D</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg-health: #0a1628;
  --accent: #38bdf8;
  --positive: #22d3ee;
  --negative: #f43f5e;
  --neutral: #94a3b8;
  --text: #e2e8f0;
  --text-dim: #64748b;
  --panel-bg: rgba(10, 22, 40, 0.88);
  --panel-border: rgba(56, 189, 248, 0.12);
}

html, body {
  width: 100%; height: 100%;
  overflow: hidden;
  font-family: 'DM Mono', monospace;
  color: var(--text);
  background: var(--bg-health);
}

#bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
#globe-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; cursor: grab; }
#globe-canvas:active { cursor: grabbing; }

.ui-layer { position: fixed; z-index: 10; pointer-events: none; }
.ui-layer > * { pointer-events: auto; }

/* Loading overlay */
#loadingOverlay {
  position: fixed; inset: 0; z-index: 999;
  background: #060e1a;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  transition: opacity 0.8s;
}
#loadingOverlay.hidden { opacity: 0; pointer-events: none; }
.loading-spinner {
  width: 48px; height: 48px;
  border: 2px solid rgba(56,189,248,0.15);
  border-top-color: #38bdf8;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  margin-top: 20px; font-size: 12px; color: var(--text-dim);
  letter-spacing: 2px; text-transform: uppercase;
}
.loading-sub {
  margin-top: 8px; font-size: 11px; color: rgba(100,116,139,0.6);
}

/* Header */
.header {
  top: 0; left: 0; right: 0;
  display: flex; justify-content: space-between; align-items: flex-start;
  padding: 20px 28px;
}
.title-block h1 {
  font-family: 'Instrument Serif', serif;
  font-size: 26px; font-weight: 400; letter-spacing: -0.5px;
}
.title-block .subtitle { font-size: 10px; color: var(--text-dim); margin-top: 3px; letter-spacing: 1.5px; text-transform: uppercase; }

.global-health-badge {
  display: flex; align-items: center; gap: 12px;
  background: var(--panel-bg); border: 1px solid var(--panel-border);
  border-radius: 12px; padding: 10px 18px; backdrop-filter: blur(20px);
}
.health-indicator {
  width: 10px; height: 10px; border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { opacity:1; box-shadow: 0 0 8px currentColor; }
  50% { opacity:0.5; box-shadow: 0 0 16px currentColor; }
}
.health-label { font-size: 10px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; }
.health-value { font-size: 17px; font-weight: 500; }

/* Ticker */
.ticker-strip {
  top: 80px; left: 0; right: 0; overflow: hidden; height: 34px;
  background: rgba(10,22,40,0.6);
  border-top: 1px solid var(--panel-border); border-bottom: 1px solid var(--panel-border);
}
.ticker-track { display: flex; gap: 36px; animation: scroll 80s linear infinite; white-space: nowrap; padding: 7px 0; }
@keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.ticker-item { font-size: 11px; display: flex; gap: 6px; align-items: center; flex-shrink: 0; }
.ticker-name { color: var(--text-dim); }
.ticker-value { color: var(--text); font-weight: 500; }
.ticker-change { font-weight: 500; }
.ticker-change.up { color: #22d3ee; }
.ticker-change.down { color: #f43f5e; }
.ticker-sep { color: rgba(148,163,184,0.15); }

/* Panels */
.panel-left { top: 128px; left: 20px; width: 310px; max-height: calc(100vh - 220px); }
.panel-right { top: 128px; right: 20px; width: 290px; max-height: calc(100vh - 220px); }
.panel {
  background: var(--panel-bg); border: 1px solid var(--panel-border);
  border-radius: 14px; backdrop-filter: blur(24px); overflow: hidden;
}
.panel-header {
  padding: 14px 18px 10px;
  border-bottom: 1px solid var(--panel-border);
  display: flex; justify-content: space-between; align-items: center;
}
.panel-title { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim); }
.panel-toggle { display: flex; gap: 1px; }
.panel-toggle button {
  background: transparent; border: 1px solid var(--panel-border);
  color: var(--text-dim); font-family: 'DM Mono', monospace;
  font-size: 9px; padding: 3px 9px; cursor: pointer; transition: all 0.2s;
}
.panel-toggle button:first-child { border-radius: 5px 0 0 5px; }
.panel-toggle button:last-child { border-radius: 0 5px 5px 0; }
.panel-toggle button.active { background: rgba(56,189,248,0.15); color: var(--accent); border-color: var(--accent); }

.country-list {
  padding: 6px 0; max-height: calc(100vh - 300px); overflow-y: auto;
  scrollbar-width: thin; scrollbar-color: rgba(56,189,248,0.2) transparent;
}
.country-row {
  display: grid; grid-template-columns: 26px 1fr 62px 56px;
  align-items: center; padding: 6px 18px; gap: 6px;
  transition: background 0.15s; cursor: pointer;
}
.country-row:hover { background: rgba(56,189,248,0.05); }
.country-rank { font-size: 9px; color: var(--text-dim); text-align: right; }
.country-name { font-size: 11px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.country-gdp { font-size: 10px; color: var(--text-dim); text-align: right; }
.country-growth { font-size: 10px; font-weight: 500; text-align: right; padding: 2px 6px; border-radius: 4px; }

.search-box {
  padding: 8px 18px;
  border-bottom: 1px solid var(--panel-border);
}
.search-box input {
  width: 100%; background: rgba(56,189,248,0.05);
  border: 1px solid var(--panel-border); border-radius: 6px;
  padding: 6px 10px; font-family: 'DM Mono', monospace;
  font-size: 10px; color: var(--text); outline: none;
}
.search-box input::placeholder { color: var(--text-dim); }

.market-grid { padding: 10px 14px; display: flex; flex-direction: column; gap: 4px; max-height: calc(100vh - 300px); overflow-y: auto; }
.market-row {
  display: grid; grid-template-columns: 1fr auto auto;
  align-items: center; gap: 10px; padding: 6px 6px; border-radius: 6px;
  transition: background 0.15s;
}
.market-row:hover { background: rgba(56,189,248,0.05); }
.market-name { font-size: 10px; }
.market-region { font-size: 8px; color: var(--text-dim); margin-top: 1px; }
.market-price { font-size: 11px; font-weight: 500; text-align: right; }
.market-change { font-size: 10px; font-weight: 500; text-align: right; min-width: 56px; }

/* Legend */
.legend-bar {
  bottom: 20px; left: 50%; transform: translateX(-50%);
  display: flex; align-items: center; gap: 14px;
  background: var(--panel-bg); border: 1px solid var(--panel-border);
  border-radius: 10px; padding: 10px 20px; backdrop-filter: blur(20px);
}
.legend-gradient { width: 180px; height: 8px; border-radius: 4px; background: linear-gradient(90deg, #f43f5e, #fb923c, #facc15, #a3e635, #22d3ee, #38bdf8); }
.legend-labels { display: flex; justify-content: space-between; width: 180px; margin-top: 2px; }
.legend-label { font-size: 8px; color: var(--text-dim); }
.legend-title { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

.data-source {
  bottom: 56px; left: 50%; transform: translateX(-50%);
  font-size: 9px; color: rgba(100,116,139,0.5); letter-spacing: 0.5px;
  text-align: center;
}

/* Tooltip */
.tooltip {
  position: fixed; z-index: 100;
  background: rgba(10,22,40,0.95); border: 1px solid var(--panel-border);
  border-radius: 10px; padding: 12px 16px; backdrop-filter: blur(20px);
  pointer-events: none; opacity: 0; transition: opacity 0.15s; min-width: 180px;
}
.tooltip.visible { opacity: 1; }
.tooltip-country { font-size: 13px; font-weight: 500; margin-bottom: 6px; }
.tooltip-row { display: flex; justify-content: space-between; gap: 16px; margin-bottom: 3px; }
.tooltip-key { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.5px; }
.tooltip-val { font-size: 11px; font-weight: 500; }

@media (max-width: 1100px) {
  .panel-left, .panel-right { display: none; }
}
@media (max-width: 600px) {
  .header { padding: 12px 16px; }
  .title-block h1 { font-size: 18px; }
  .global-health-badge { padding: 8px 12px; }
}
</style>
</head>
<body>

<div id="loadingOverlay">
  <div class="loading-spinner"></div>
  <div class="loading-text" id="loadingText">Fetching live economic data</div>
  <div class="loading-sub" id="loadingSub">World Bank API + Market Data</div>
</div>

