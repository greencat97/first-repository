const bgCanvas=document.getElementById('bg-canvas');
const bgCtx=bgCanvas.getContext('2d');
function resizeBg(){bgCanvas.width=window.innerWidth;bgCanvas.height=window.innerHeight;}
resizeBg(); window.addEventListener('resize',resizeBg);

let bgTime=0;
function getHealthHue(){
  const totalGdp=countries.reduce((s,c)=>s+c.gdp,0)||1;
  const wg=countries.reduce((s,c)=>s+c.growth*c.gdp,0)/totalGdp;
  const mc=MARKETS.reduce((s,m)=>s+m.change,0)/MARKETS.length;
  const score=wg*0.7+mc*0.3;
  return {hue:Math.max(170,Math.min(225,180+score*8)),wg,mc,score};
}

function drawBackground(){
  bgTime+=0.002;
  const w=bgCanvas.width,h=bgCanvas.height;
  const{hue}=getHealthHue();

  const grad=bgCtx.createRadialGradient(w*0.5,h*0.5,0,w*0.5,h*0.5,w*0.7);
  const sat=55+Math.sin(bgTime)*8;
  grad.addColorStop(0,`hsl(${hue+10},${sat}%,11%)`);
  grad.addColorStop(0.5,`hsl(${hue},${sat-15}%,7%)`);
  grad.addColorStop(1,`hsl(${hue-15},${sat-25}%,3%)`);
  bgCtx.fillStyle=grad;
  bgCtx.fillRect(0,0,w,h);

  for(let i=0;i<100;i++){
    const x=((i*137.508+bgTime*15)%w);
    const y=((i*97.3+Math.sin(bgTime+i*0.5)*25)%h);
    const alpha=0.06+Math.sin(bgTime*2+i)*0.03;
    bgCtx.beginPath();
    bgCtx.arc(x,y,0.8+Math.sin(i*0.3)*0.4,0,Math.PI*2);
    bgCtx.fillStyle=`hsla(${hue+30},50%,65%,${alpha})`;
    bgCtx.fill();
  }

  for(let ring=0;ring<3;ring++){
    const r=((bgTime*60+ring*180)%(w*0.7));
    bgCtx.beginPath();
    bgCtx.arc(w*0.5,h*0.5,r,0,Math.PI*2);
    bgCtx.strokeStyle=`hsla(${hue+20},40%,45%,${Math.max(0,0.012*(1-r/(w*0.7)))})`;
    bgCtx.lineWidth=1;
    bgCtx.stroke();
  }
  requestAnimationFrame(drawBackground);
}
drawBackground();

