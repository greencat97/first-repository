const earthTexURL3='https://cdn.jsdelivr.net/npm/three-globe/example/img/earth-night.jpg';

// Try multiple texture sources
let textureLoaded=false;
function tryLoadTexture(url,fallbackUrl){
  textureLoader.load(url,
    tex=>{
      if(!textureLoaded){
        textureLoaded=true;
        globeMat.map=tex;
        globeMat.color=new THREE.Color(0xffffff);
        globeMat.needsUpdate=true;
      }
    },
    undefined,
    ()=>{
      if(fallbackUrl&&!textureLoaded) tryLoadTexture(fallbackUrl);
    }
  );
}
tryLoadTexture(earthTexURL2,earthTexURL3);

const globe=new THREE.Mesh(globeGeo,globeMat);
scene.add(globe);

// Grid lines (subtle, on top of texture)
const gridMat=new THREE.LineBasicMaterial({color:0x38bdf8,transparent:true,opacity:0.06});
for(let lat=-60;lat<=60;lat+=30){
  const pts=[];
  for(let lon=0;lon<=360;lon+=3) pts.push(latLonToVec3(lat,lon,globeRadius*1.002));
  scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),gridMat));
}
for(let lon=0;lon<360;lon+=30){
  const pts=[];
  for(let lat=-90;lat<=90;lat+=3) pts.push(latLonToVec3(lat,lon,globeRadius*1.002));
  scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),gridMat));
}

// Atmosphere
const atmosGeo=new THREE.SphereGeometry(globeRadius*1.1,64,48);
const atmosMat=new THREE.ShaderMaterial({
  vertexShader:`varying vec3 vNormal;void main(){vNormal=normalize(normalMatrix*normal);gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}`,
  fragmentShader:`varying vec3 vNormal;void main(){float i=pow(0.6-dot(vNormal,vec3(0,0,1)),3.0);gl_FragColor=vec4(0.22,0.72,0.95,i*0.35);}`,
  side:THREE.BackSide,blending:THREE.AdditiveBlending,transparent:true,
});
scene.add(new THREE.Mesh(atmosGeo,atmosMat));

