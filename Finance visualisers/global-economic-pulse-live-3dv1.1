let sortMode='gdp';
let searchTerm='';

function renderCountryList(){
  const list=document.getElementById('countryList');
  let filtered=countries.filter(c=>c.gdp>0);
  if(searchTerm) filtered=filtered.filter(c=>c.name.toLowerCase().includes(searchTerm));
  const sorted=[...filtered].sort((a,b)=>sortMode==='gdp'?b.gdp-a.gdp:b.growth-a.growth);
  list.innerHTML=sorted.slice(0,60).map((c,i)=>{
    const col=growthToColor(c.growth);
    const sign=c.growth>=0?'+':'';
    const gdpStr=c.gdp>=1000?`$${(c.gdp/1000).toFixed(1)}T`:`$${c.gdp}B`;
    return`<div class="country-row" onmouseenter="highlightCountry('${c.code}')" onmouseleave="unhighlightCountry()">
      <span class="country-rank">${i+1}</span>
      <span class="country-name">${c.name}</span>
      <span class="country-gdp">${gdpStr}</span>
      <span class="country-growth" style="background:rgba(${col.r},${col.g},${col.b},0.15);color:${col.hex}">${sign}${c.growth}%</span>
    </div>`;
  }).join('');
}

function renderMarkets(){
