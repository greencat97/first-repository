function buildCountryBars(){
  // Clear old
  while(countryGroup.children.length>0) countryGroup.remove(countryGroup.children[0]);
  countryMeshes=[];

  const maxGdp=Math.max(...countries.map(c=>c.gdp),1);

  countries.forEach(c=>{
    if(!c.lat||!c.lon||c.gdp<=0) return;
    const pos=latLonToVec3(c.lat,c.lon,globeRadius);
    const normal=pos.clone().normalize();

    const maxH=0.55;
    const barH=Math.max(0.015,Math.pow(c.gdp/maxGdp,0.4)*maxH);
    const barW=Math.max(0.008,Math.min(0.03,Math.sqrt(Math.max(c.pop,1)/1440)*0.035));

    const color=growthToThreeColor(c.growth);
    const barGeo=new THREE.CylinderGeometry(barW*0.6,barW,barH,6);
    barGeo.translate(0,barH/2,0);
    const barMat=new THREE.MeshPhongMaterial({
      color,emissive:color.clone().multiplyScalar(0.25),
      transparent:true,opacity:0.85,shininess:50,
    });
    const bar=new THREE.Mesh(barGeo,barMat);
    bar.position.copy(pos);
    bar.lookAt(pos.clone().add(normal));
    bar.rotateX(Math.PI/2);
    bar.userData={country:c};
    countryGroup.add(bar);
    countryMeshes.push(bar);

    // Base dot
    const dotGeo=new THREE.SphereGeometry(barW*1.3,8,6);
    const dotMat=new THREE.MeshBasicMaterial({color,transparent:true,opacity:0.4});
    const dot=new THREE.Mesh(dotGeo,dotMat);
    dot.position.copy(pos.clone().multiplyScalar(1.001));
    countryGroup.add(dot);
  });
}

// Trade arcs
function buildArcs(){
  const arcMat=new THREE.LineBasicMaterial({color:0x38bdf8,transparent:true,opacity:0.05});
  const conns=[
    ['USA','CHN'],['USA','GBR'],['USA','JPN'],['USA','DEU'],['CHN','JPN'],
    ['CHN','KOR'],['DEU','FRA'],['IND','ARE'],['AUS','CHN'],['BRA','USA'],
    ['GBR','DEU'],['JPN','KOR'],['SGP','CHN'],['IND','USA'],['SAU','CHN'],
    ['DEU','CHN'],['FRA','USA'],['MEX','USA'],['CAN','USA'],['IDN','CHN'],
  ];
  conns.forEach(([a,b])=>{
    const ca=countryMap.get(a),cb=countryMap.get(b);
    if(!ca||!cb) return;
    const p1=latLonToVec3(ca.lat,ca.lon,globeRadius*1.003);
    const p2=latLonToVec3(cb.lat,cb.lon,globeRadius*1.003);
    const mid=p1.clone().add(p2).multiplyScalar(0.5);
    mid.normalize().multiplyScalar(globeRadius+p1.distanceTo(p2)*0.28);
    const pts=new THREE.QuadraticBezierCurve3(p1,mid,p2).getPoints(36);
    scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),arcMat));
  });
}

// ============================================================
//  INTERACTION
// ============================================================
let isDragging=false,prevMouse={x:0,y:0},rotVel={x:0,y:0},autoRotate=true;
const raycaster=new THREE.Raycaster();
const mousePos=new THREE.Vector2();
let highlightedCode=null;

canvas.addEventListener('mousedown',e=>{isDragging=true;autoRotate=false;prevMouse={x:e.clientX,y:e.clientY};});
canvas.addEventListener('mousemove',e=>{
  mousePos.x=(e.clientX/window.innerWidth)*2-1;
  mousePos.y=-(e.clientY/window.innerHeight)*2+1;
  if(isDragging){
    rotVel.x=(e.clientY-prevMouse.y)*0.003;
    rotVel.y=(e.clientX-prevMouse.x)*0.003;
    prevMouse={x:e.clientX,y:e.clientY};
  }
  raycaster.setFromCamera(mousePos,camera);
  const hits=raycaster.intersectObjects(countryMeshes);
  const tt=document.getElementById('tooltip');
  if(hits.length>0){
    const c=hits[0].object.userData.country;
    if(c){
      const col=growthToColor(c.growth);
      const sign=c.growth>=0?'+':'';
      const gdpStr=c.gdp>=1000?`$${(c.gdp/1000).toFixed(1)}T`:`$${c.gdp}B`;
      tt.innerHTML=`<div class="tooltip-country" style="color:${col.hex}">${c.name}</div>
        <div class="tooltip-row"><span class="tooltip-key">GDP</span><span class="tooltip-val">${gdpStr}</span></div>
        <div class="tooltip-row"><span class="tooltip-key">Growth</span><span class="tooltip-val" style="color:${col.hex}">${sign}${c.growth}%</span></div>
        <div class="tooltip-row"><span class="tooltip-key">Population</span><span class="tooltip-val">${c.pop}M</span></div>
        <div class="tooltip-row"><span class="tooltip-key">Region</span><span class="tooltip-val">${c.region}</span></div>`;
      tt.style.left=Math.min(e.clientX+16,window.innerWidth-220)+'px';
      tt.style.top=(e.clientY-20)+'px';
      tt.classList.add('visible');
    }
  } else { tt.classList.remove('visible'); }
});
canvas.addEventListener('mouseup',()=>{isDragging=false;clearTimeout(autoTimer);autoTimer=setTimeout(()=>{autoRotate=true;},5000);});
canvas.addEventListener('mouseleave',()=>{isDragging=false;document.getElementById('tooltip').classList.remove('visible');});
canvas.addEventListener('wheel',e=>{camera.position.z=Math.max(2.2,Math.min(9,camera.position.z+e.deltaY*0.003));},{passive:true});

// Touch
canvas.addEventListener('touchstart',e=>{isDragging=true;autoRotate=false;prevMouse={x:e.touches[0].clientX,y:e.touches[0].clientY};},{passive:true});
canvas.addEventListener('touchmove',e=>{if(isDragging&&e.touches.length===1){rotVel.x=(e.touches[0].clientY-prevMouse.y)*0.003;rotVel.y=(e.touches[0].clientX-prevMouse.x)*0.003;prevMouse={x:e.touches[0].clientX,y:e.touches[0].clientY};}},{passive:true});
canvas.addEventListener('touchend',()=>{isDragging=false;clearTimeout(autoTimer);autoTimer=setTimeout(()=>{autoRotate=true;},4000);});

window.highlightCountry=code=>{highlightedCode=code;};
window.unhighlightCountry=()=>{highlightedCode=null;};

let autoTimer;

// ============================================================
//  ANIMATION
// ============================================================
let time=0;
function animate(){
  requestAnimationFrame(animate);
  time+=0.008;

  if(autoRotate){countryGroup.rotation.y+=0.0015;globe.rotation.y+=0.0015;}
  if(!isDragging){rotVel.x*=0.94;rotVel.y*=0.94;}
  countryGroup.rotation.x+=rotVel.x;
  countryGroup.rotation.y+=rotVel.y;
  globe.rotation.x=countryGroup.rotation.x;
  globe.rotation.y=countryGroup.rotation.y;

  countryMeshes.forEach(mesh=>{
    const c=mesh.userData.country;if(!c) return;
    const isH=highlightedCode===c.code;
    const tgt=isH?1.0:(highlightedCode?0.25:0.85);
    mesh.material.opacity+=(tgt-mesh.material.opacity)*0.1;
    mesh.scale.y=1+Math.sin(time*2+c.gdp*0.001)*0.025;
    mesh.material.emissive=growthToThreeColor(c.growth).multiplyScalar(isH?0.5:0.2);
  });

  renderer.render(scene,camera);
}

window.addEventListener('resize',()=>{
  camera.aspect=window.innerWidth/window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth,window.innerHeight);
});

// ============================================================
//  INIT
// ============================================================
async function init(){
  const loadText=document.getElementById('loadingText');
  const loadSub=document.getElementById('loadingSub');

  // Check cache first
  if(loadCachedData()){
    loadText.textContent='Loaded cached data';
    loadSub.textContent='Refreshing from World Bank API...';
    // Still fetch fresh in background
    fetchLiveData().then(()=>{
      buildCountryBars(); renderCountryList(); updateHealthBadge();
      updateTimestamp();
    }).catch(()=>{});
  } else {
    await fetchLiveData();
  }

  loadText.textContent='Building 3D globe';
  loadSub.textContent='Plotting '+countries.filter(c=>c.gdp>0).length+' economies';

  buildCountryBars();
  buildArcs();
  buildTicker();
  renderCountryList();
  renderMarkets();
  updateHealthBadge();
  updateTimestamp();

  animate();

  // Hide loading
  setTimeout(()=>{document.getElementById('loadingOverlay').classList.add('hidden');},800);

  // Schedule refresh every 24 hours
  setInterval(async()=>{
    await fetchLiveData();
    buildCountryBars();
    renderCountryList();
    updateHealthBadge();
    updateTimestamp();
  }, REFRESH_INTERVAL);
}

function updateTimestamp(){
  const ts=lastFetch||new Date();
  const dateStr=ts.toLocaleDateString('en-AU',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
  document.getElementById('liveIndicator').textContent=`● LIVE — Last updated: ${dateStr}`;
  document.getElementById('dataSource').textContent=`GDP & Growth: World Bank API (NY.GDP.MKTP) · Markets: Composite sources · Refreshes every 24h`;
}

init();
</script>
</body>
</html>
