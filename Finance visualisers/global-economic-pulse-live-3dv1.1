// ============================================================
//  LIVE DATA FETCHING — World Bank API (no key needed)
// ============================================================
const WB_GDP_URL = 'https://api.worldbank.org/v2/country/all/indicator/NY.GDP.MKTP.CD?format=json&per_page=300&date=2023:2024&mrnev=1';
const WB_GROWTH_URL = 'https://api.worldbank.org/v2/country/all/indicator/NY.GDP.MKTP.KD.ZG?format=json&per_page=300&date=2023:2024&mrnev=1';

let lastFetch = null;
const REFRESH_INTERVAL = 24 * 60 * 60 * 1000; // 24 hours

async function fetchLiveData() {
  const loadText = document.getElementById('loadingText');
  const loadSub = document.getElementById('loadingSub');
  let gdpData = null, growthData = null;

  try {
    loadText.textContent = 'Fetching GDP data from World Bank';
    loadSub.textContent = 'api.worldbank.org — NY.GDP.MKTP.CD';
    const gdpRes = await fetch(WB_GDP_URL);
    const gdpJson = await gdpRes.json();
    if (gdpJson && gdpJson[1]) gdpData = gdpJson[1];
  } catch(e) { console.warn('GDP fetch failed, using fallback data', e); }

  try {
    loadText.textContent = 'Fetching growth rates';
    loadSub.textContent = 'api.worldbank.org — NY.GDP.MKTP.KD.ZG';
    const growthRes = await fetch(WB_GROWTH_URL);
    const growthJson = await growthRes.json();
    if (growthJson && growthJson[1]) growthData = growthJson[1];
  } catch(e) { console.warn('Growth fetch failed, using fallback data', e); }

  // Merge live data into our country database
  if (gdpData) {
    gdpData.forEach(d => {
      if (!d.value || !d.countryiso3code) return;
      const c = countryMap.get(d.countryiso3code);
      if (c) c.gdp = Math.round(d.value / 1e9); // Convert to billions
    });
  }

  if (growthData) {
    growthData.forEach(d => {
      if (d.value === null || !d.countryiso3code) return;
      const c = countryMap.get(d.countryiso3code);
      if (c) c.growth = Math.round(d.value * 100) / 100;
    });
  }

  countries = Array.from(countryMap.values());
  lastFetch = new Date();

  // Save to localStorage for 24hr cache
  try {
    localStorage.setItem('gep_data', JSON.stringify({ countries: countries.map(c=>({code:c.code,gdp:c.gdp,growth:c.growth})), ts: Date.now() }));
  } catch(e) {}

  return { gdpData, growthData };
}

function loadCachedData() {
  try {
    const cached = JSON.parse(localStorage.getItem('gep_data'));
    if (cached && Date.now() - cached.ts < REFRESH_INTERVAL) {
      cached.countries.forEach(d => {
        const c = countryMap.get(d.code);
        if (c) { c.gdp = d.gdp; c.growth = d.growth; }
      });
      countries = Array.from(countryMap.values());
      lastFetch = new Date(cached.ts);
      return true;
    }
  } catch(e) {}
  return false;
}

