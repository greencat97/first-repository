function growthToColor(growth) {
  const t = Math.max(0, Math.min(1, (growth + 5) / 12));
  const stops = [
    {p:0.0,r:244,g:63,b:94},{p:0.18,r:251,g:146,b:60},
    {p:0.33,r:250,g:204,b:21},{p:0.5,r:163,g:230,b:53},
    {p:0.7,r:34,g:211,b:238},{p:1.0,r:56,g:189,b:248},
  ];
  let lo=stops[0],hi=stops[stops.length-1];
  for(let i=0;i<stops.length-1;i++){
    if(t>=stops[i].p&&t<=stops[i+1].p){lo=stops[i];hi=stops[i+1];break;}
  }
  const f=(t-lo.p)/(hi.p-lo.p);
  const r=Math.round(lo.r+(hi.r-lo.r)*f);
  const g=Math.round(lo.g+(hi.g-lo.g)*f);
  const b=Math.round(lo.b+(hi.b-lo.b)*f);
  return {r,g,b,hex:`rgb(${r},${g},${b})`};
}

function growthToThreeColor(growth){
  const c=growthToColor(growth);
  return new THREE.Color(c.r/255,c.g/255,c.b/255);
}

function latLonToVec3(lat,lon,radius){
  const phi=(90-lat)*Math.PI/180;
  const theta=(lon+180)*Math.PI/180;
  return new THREE.Vector3(
    -radius*Math.sin(phi)*Math.cos(theta),
    radius*Math.cos(phi),
    radius*Math.sin(phi)*Math.sin(theta)
  );
}

